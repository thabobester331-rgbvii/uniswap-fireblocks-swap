// ==========================================
// Order Creation
// ==========================================

export async function createOrder(request: OrderRequest): Promise<OrderResult> {
  const client = getFireblocksClient();
  const config = getConfig();
  
  const sourceVault = request.sourceVaultAccountId || config.fireblocks.sourceVaultAccountId;
  const destVault = request.destinationVaultAccountId || config.fireblocks.destinationVaultAccountId;
  
  const idempotencyKey = generateIdempotencyKey("order");
  
  try {
    const response = await client.tradingBeta.createOrder({
      createOrderRequest: {
        via: {
          type: "PROVIDER",
          providerId: request.providerId || "UNISWAP_CLASSIC",
        },
        executionRequestDetails: {
          type: "QUOTE",
          quoteId: request.quoteId,
        },
        settlement: {
          type: "DVP",
          sourceAccount: {
            type: "VAULT_ACCOUNT",
            accountId: sourceVault,
          },
          destinationAccount: {
            type: "VAULT_ACCOUNT",
            accountId: destVault,
          },
        },
      },
      idempotencyKey,
    });
    
    const order = response.data;
    
    return {
      orderId: order.id,
      status: order.status,
      providerId: order.via?.providerId || "UNISWAP_CLASSIC",
      quoteId: request.quoteId,
      rawOrder: order,
    };
  } catch (error) {
    return handleError(error, "Failed to create order");
  }
}

// ==========================================
// Order Monitoring
// ==========================================

export async function getOrderStatus(orderId: string): Promise<OrderResult> {
  const client = getFireblocksClient();
  
  try {
    const response = await client.tradingBeta.getOrder({ orderId });
    const order = response.data;
    
    return {
      orderId: order.id,
      status: order.status,
      providerId: order.via?.providerId || "UNKNOWN",
      quoteId: order.executionRequestDetails?.quoteId || "",
      rawOrder: order,
    };
  } catch (error) {
    return handleError(error, `Failed to get order status for ${orderId}`);
  }
}

export async function waitForOrderCompletion(
  orderId: string,
  options: {
    maxAttempts?: number;
    pollIntervalMs?: number;
  } = {}
): Promise<OrderResult> {
  const { maxAttempts = 60, pollIntervalMs = 5000 } = options;
  
  console.log(`⏳ Monitoring order ${orderId}...`);
  
  for (let attempt = 1; attempt <= maxAttempts; attempt++) {
    const order = await getOrderStatus(orderId);
    
    console.log(`   Attempt ${attempt}/${maxAttempts}: Status = ${order.status}`);
    
    if (order.status === "COMPLETED") {
      console.log(`✅ Order completed successfully!`);
      return order;
    }
    
    if (order.status === "FAILED" || order.status === "REJECTED") {
      throw new SwapError(
        `Order ${orderId} failed with status: ${order.status}`,
        "ORDER_FAILED",
        order
      );
    }
    
    if (attempt < maxAttempts) {
      await sleep(pollIntervalMs);
    }
  }
  
  throw new SwapError(
    `Order ${orderId} did not complete within ${maxAttempts} attempts`,
    "TIMEOUT"
  );
}

// ==========================================
// Full Swap Flow (Quote + Execute + Monitor)
// ==========================================

export async function executeSwap(
  quoteRequest: QuoteRequest,
  options: {
    waitForCompletion?: boolean;
    maxAttempts?: number;
    pollIntervalMs?: number;
  } = {}
): Promise<SwapResult> {
  const { waitForCompletion = true, maxAttempts = 60, pollIntervalMs = 5000 } = options;
  
  // Step 1: Create quote
  console.log("\\n📊 Step 1: Creating quote...");
  const quote = await createQuote(quoteRequest);
  console.log(`   Quote ID: ${quote.quoteId}`);
  console.log(`   Expected output: ${quote.quoteAmount} ${quote.quoteAssetId}`);
  
  // Step 2: Create order from quote
  console.log("\\n📝 Step 2: Creating order...");
  const order = await createOrder({
    quoteId: quote.quoteId,
    providerId: quote.providerId,
    sourceVaultAccountId: quoteRequest.sourceVaultAccountId,
    destinationVaultAccountId: quoteRequest.destinationVaultAccountId,
  });
  console.log(`   Order ID: ${order.orderId}`);
  console.log(`   Initial status: ${order.status}`);
  
  // Step 3: Monitor if requested
  let finalOrder = order;
  if (waitForCompletion) {
    console.log("\\n⏳ Step 3: Monitoring order...");
    finalOrder = await waitForOrderCompletion(order.orderId, {
      maxAttempts,
      pollIntervalMs,
    });
  }
  
  // Extract transaction hash if available
  const txHash = finalOrder.rawOrder?.transactionHash;
  const blockExplorerUrl = txHash
    ? `https://etherscan.io/tx/${txHash}`
    : undefined;
  
  return {
    order: finalOrder,
    finalStatus: finalOrder.status,
    transactionHash: txHash,
    blockExplorerUrl,
  };
}

